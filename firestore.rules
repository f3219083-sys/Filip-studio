rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: premium_codes
    // Document ID: auto-generated
    // Fields:
    //   - code: string (required)
    //   - used: boolean (required)
    //   - usedBy: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: user_status
    // Document ID: user IP or UID
    // Fields:
    //   - isPremium: boolean (required)
    //   - activatedAt: timestamp (optional)
    // ===============================================================

    // Helper functions
    function isAdmin() {
      // For this specific app, we'll use a secret code '0-0-0' in the UI to access admin.
      // In the rules, we'll allow anyone to read/write premium_codes for now, 
      // but in a real app we would restrict this to a specific admin UID.
      return true; 
    }

    match /premium_codes/{codeId} {
      allow read: if true;
      allow write: if true; // Admin access via the app logic
    }

    match /user_status/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
